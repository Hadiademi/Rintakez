NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used to look up recipient emails for notification emails.
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — email notifications (Resend). With no RESEND_API_KEY the email
# feature is a no-op; in-app notifications still work. Set all three in prod.
RESEND_API_KEY=
EMAIL_FROM="Rintakez <noreply@yourdomain.ch>"
NEXT_PUBLIC_APP_URL=https://yourdomain.ch

# Optional — Google sign-in. Local only (production uses the Supabase dashboard).
# Set both, flip [auth.external.google] enabled=true in supabase/config.toml, restart Supabase.
GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
