NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used to look up recipient emails for notification emails.
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the deployed site. Used for absolute links in emails and
# for sitemap / robots / canonical metadata. Set to your real domain in prod.
NEXT_PUBLIC_SITE_URL=https://yourdomain.ch

# Optional — email notifications (Resend). With no RESEND_API_KEY the email
# feature is a no-op; in-app notifications still work.
RESEND_API_KEY=
EMAIL_FROM="Rintakez <noreply@yourdomain.ch>"

# Optional — Google sign-in. Local only (production uses the Supabase dashboard).
# Set both, flip [auth.external.google] enabled=true in supabase/config.toml, restart Supabase.
GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Optional — observability. captureError() forwards errors here when set
# (Sentry/Logflare/Slack-style sink). Swap for @sentry/nextjs later if desired.
ERROR_WEBHOOK_URL=

# Optional — privacy-first analytics (Plausible, cookieless). Inert if unset.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Distributed rate limiting (Upstash Redis, REST). REQUIRED in production:
# without these the limiter falls back to an in-process Map that does NOT hold
# across serverless instances. Create a free Redis DB at upstash.com and paste
# its REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
